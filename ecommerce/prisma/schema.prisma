model Order {
  id                      String      @id @default(uuid())
  orderCode               String      @unique @map("order_code") @db.VarChar(30)
  userId                  String      @map("user_id")
  user                    User        @relation(fields: [userId], references: [id])
  shippingAddressSnapshot Json        @map("shipping_address_snapshot")
  addressId               String?     @map("address_id")
  address                 UserAddress? @relation(fields: [addressId], references: [id])
  couponId                String?     @map("coupon_id")
  coupon                  Coupon?     @relation(fields: [couponId], references: [id])
  status                  OrderStatus @default(pending)
  subtotal                Decimal     @db.Decimal(15, 2)
  discountAmt             Decimal     @default(0) @map("discount_amt") @db.Decimal(15, 2)
  shippingFee             Decimal     @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  total                   Decimal     @db.Decimal(15, 2)
  note                    String?
  orderedAt               DateTime    @default(now()) @map("ordered_at")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  items     OrderItem[]
  payments  Payment[]
  shipments Shipment[]

  @@index([userId])
  @@index([status])
  @@index([orderCode])
  @@map("orders")
}

model OrderItem {
  id          String         @id @default(uuid())
  orderId     String         @map("order_id")
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId   String?        @map("variant_id")
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  productName String         @map("product_name") @db.VarChar(500)
  variantName String?        @map("variant_name") @db.VarChar(300)
  sku         String?        @db.VarChar(100)
  quantity    Int
  unitPrice   Decimal        @map("unit_price") @db.Decimal(15, 2)
  discountAmt Decimal        @default(0) @map("discount_amt") @db.Decimal(15, 2)
  lineTotal   Decimal        @map("line_total") @db.Decimal(15, 2)

  review      Review?

  @@index([orderId])
  @@map("order_items")
}

