model Warehouse {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(200)
  code       String      @unique @db.VarChar(20)
  address    String?
  province   String?     @db.VarChar(100)
  managerId  String?     @map("manager_id")
  manager    User?       @relation(fields: [managerId], references: [id])
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  inventories Inventory[]
  shipments   Shipment[]

  @@map("warehouses")
}

model Inventory {
  id           BigInt    @id @default(autoincrement())
  variantId    String    @map("variant_id")
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  warehouseId  Int       @map("warehouse_id")
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  qtyAvailable Int       @default(0) @map("qty_available")
  qtyReserved  Int       @default(0) @map("qty_reserved")
  reorderPoint Int       @default(10) @map("reorder_point")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  logs         InventoryLog[]

  @@unique([variantId, warehouseId])
  @@map("inventory")
}

model InventoryLog {
  id           BigInt          @id @default(autoincrement())
  inventoryId  BigInt          @map("inventory_id")
  inventory    Inventory       @relation(fields: [inventoryId], references: [id])
  action       InventoryAction
  qtyChange    Int             @map("qty_change")
  qtyBefore    Int             @map("qty_before")
  qtyAfter     Int             @map("qty_after")
  referenceType String?        @map("reference_type") @db.VarChar(50)
  referenceId  String?         @map("reference_id") @db.VarChar(100)
  note         String?
  createdBy    String?         @map("created_by")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@index([inventoryId])
  @@index([referenceId])
  @@map("inventory_logs")
}

