// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  banned
}

enum ProductStatus {
  draft
  active
  archived
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentMethod {
  cod
  bank_transfer
  momo
  vnpay
  zalopay
  stripe
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum ShipmentStatus {
  pending
  picked_up
  in_transit
  out_for_delivery
  delivered
  failed
  returned
}

enum CouponType {
  percent
  fixed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum InventoryAction {
  import
  export
  adjustment
  reserve
  release
}

enum NotificationChannel {
  in_app
  email
  push
  sms
}

