model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(200)
  slug      String    @unique @db.VarChar(200)
  logoUrl   String?   @map("logo_url") @db.VarChar(500)
  country   String?   @db.Char(2)
  isActive  Boolean   @default(true) @map("is_active")
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("brands")
}

model Category {
  id          Int        @id @default(autoincrement())
  parentId    Int?       @map("parent_id")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  name        String     @db.VarChar(200)
  slug        String     @unique @db.VarChar(200)
  description String?
  imageUrl    String?    @map("image_url") @db.VarChar(500)
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  metaTitle   String?    @map("meta_title") @db.VarChar(300)
  metaDesc    String?    @map("meta_desc") @db.VarChar(500)
  products    Product[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id           String          @id @default(uuid())
  categoryId   Int             @map("category_id")
  category     Category        @relation(fields: [categoryId], references: [id])
  brandId      Int?            @map("brand_id")
  brand        Brand?          @relation(fields: [brandId], references: [id])
  name         String          @db.VarChar(500)
  slug         String          @unique @db.VarChar(500)
  sku          String?         @unique @db.VarChar(100)
  description  String?
  price        Decimal         @db.Decimal(15, 2)
  salePrice    Decimal?        @map("sale_price") @db.Decimal(15, 2)
  weight       Decimal?        @db.Decimal(8, 3)
  dimensions   Json?
  attributes   Json?
  status       ProductStatus   @default(draft)
  isFeatured   Boolean         @default(false) @map("is_featured")
  avgRating    Decimal         @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount  Int             @default(0) @map("review_count")
  soldCount    Int             @default(0) @map("sold_count")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  variants     ProductVariant[]
  images       ProductImage[]
  reviews      Review[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(300)
  sku        String   @unique @db.VarChar(100)
  attributes Json?
  price      Decimal  @db.Decimal(15, 2)
  salePrice  Decimal? @map("sale_price") @db.Decimal(15, 2)
  barcode    String?  @db.VarChar(100)
  imageUrl   String?  @map("image_url") @db.VarChar(500)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  cartItems   CartItem[]
  orderItems  OrderItem[]
  inventories Inventory[]

  @@index([productId])
  @@index([barcode])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?  @map("variant_id")
  url       String   @db.VarChar(500)
  altText   String?  @map("alt_text") @db.VarChar(300)
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

