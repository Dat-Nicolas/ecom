  minOrderValue   Decimal?   @map("min_order_value") @db.Decimal(15, 2)
  usageLimit      Int?       @map("usage_limit")
  usedCount       Int        @default(0) @map("used_count")
  userLimit       Int?       @map("user_limit")
  applicableTo    Json?      @map("applicable_to")
